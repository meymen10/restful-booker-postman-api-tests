              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code 200 olmalı\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking ID dönmeli\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData).to.have.property(\"bookingid\");\r",
                  "    pm.expect(jsonData.bookingid).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking bilgileri doğru kaydedilmeli\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData.booking.firstname).to.eql(\"Eymen\");\r",
                  "    pm.expect(jsonData.booking.lastname).to.eql(\"Arpaci\");\r",
                  "    pm.expect(jsonData.booking.totalprice).to.eql(250);\r",
                  "    pm.expect(jsonData.booking.depositpaid).to.eql(true);\r",
                  "    pm.expect(jsonData.booking.bookingdates.checkin).to.eql(\"2026-07-10\");\r",
                  "    pm.expect(jsonData.booking.bookingdates.checkout).to.eql(\"2026-07-15\");\r",
                  "    pm.expect(jsonData.booking.additionalneeds).to.eql(\"Breakfast\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking ID environment'a kaydedilmeli\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.environment.set(\"bookingId\", jsonData.bookingid);\r",
                  "});"
